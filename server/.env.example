# ─────────────────────────────────────────────
#  BookSwap — Server Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/bookswap?retryWrites=true&w=majority

# JWT Secret — any long random string
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Server port
PORT=5000

# ── Email notifications (optional) ──────────────────────────────────────────
# Leave blank to disable; emails will be logged to console instead.
# For Gmail: create an App Password at https://myaccount.google.com/apppasswords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM="Titus Book Exchange" <your_gmail@gmail.com>
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
